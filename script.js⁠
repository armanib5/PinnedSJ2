// State management
let posts = JSON.parse(localStorage.getItem('pinnedSJ_posts')) || [];

const corkboard = document.getElementById('corkboard');
const form = document.getElementById('postForm');
const modal = document.getElementById('postModal');

// Render posts
function render(filter = 'all') {
    corkboard.innerHTML = '';
    const filtered = filter === 'all' ? posts : posts.filter(p => p.category === filter);
    
    filtered.forEach((post, index) => {
        const div = document.createElement('div');
        div.className = 'card';
        div.innerHTML = `
            <img src="${post.img}" alt="${post.title}">
            <span class="tag">${post.category}</span>
            <h3>${post.title}</h3>
            <p>${post.desc}</p>
        `;
        corkboard.appendChild(div);
    });
}

// Handle Form Submission
form.addEventListener('submit', (e) => {
    e.preventDefault();
    const newPost = {
        title: document.getElementById('title').value,
        category: document.getElementById('category').value,
        desc: document.getElementById('desc').value,
        img: document.getElementById('imgUrl').value
    };
    posts.unshift(newPost);
    localStorage.setItem('pinnedSJ_posts', JSON.stringify(posts));
    render();
    modal.style.display = 'none';
    form.reset();
});

// UI Logic
document.getElementById('openModalBtn').onclick = () => modal.style.display = 'block';
document.querySelector('.close').onclick = () => modal.style.display = 'none';
document.querySelectorAll('.filter-btn').forEach(btn => {
    btn.onclick = () => render(btn.dataset.category);
});

render(); // Initial load
